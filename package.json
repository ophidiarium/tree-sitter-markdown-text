{
  "name": "tree-sitter-markdown-text",
  "version": "0.2.1",
  "description": "Markdown grammar for tree-sitter, with a textlint-style AST shape",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ophidiarium/tree-sitter-markdown-text.git"
  },
  "license": "MIT",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "markdown",
    "md",
    "textlint"
  ],
  "files": [
    "grammar.js",
    "html_entities.json",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.2.1",
    "eslint-config-treesitter": "^1.0.2",
    "globals": "^17.5.0",
    "prebuildify": "^6.0.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cli": "0.26.8",
    "typescript": "^6.0.3",
    "@types/node": "^24.0.0"
  },
  "overrides": {
    "eslint-plugin-jsdoc": "^62.9.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "generate": "tree-sitter generate --abi 14",
    "lint": "eslint grammar.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test bindings/node/*_test.js"
  }
}
