{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "markdown",
      "camelcase": "Markdown",
      "scope": "source.markdown",
      "path": ".",
      "file-types": [
        "md",
        "markdown",
        "mdown",
        "mkd",
        "mkdn"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injections": [
        "queries/injections.scm"
      ],
      "injection-regex": "^(markdown|md)$"
    }
  ],
  "metadata": {
    "version": "0.2.1",
    "license": "MIT",
    "description": "Markdown grammar for tree-sitter, with a textlint-style AST shape",
    "authors": [
      {
        "name": "Ophidiarium"
      }
    ],
    "links": {
      "repository": "https://github.com/ophidiarium/tree-sitter-markdown-text"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
